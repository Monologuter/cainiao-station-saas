# 菜鸟驿站 SaaS · ai-service 环境变量示例
# 复制为 .env 后按需填写；mock 模式下无需任何外部密钥即可本地起服务。
# SEC-13：示例值均为占位，生产必改。

# 服务间共享令牌：必须与 backend 的 AI_SERVICE_TOKEN 完全一致，
# ai-service 用它校验所有受保护接口的 X-Service-Token 头。
SERVICE_TOKEN="CHANGE_ME_SHARED_AI_SERVICE_TOKEN"

# OCR 提供方开关：mock（默认，本地/CI）| tencent（接腾讯云真实 OCR）。
OCR_PROVIDER="mock"

# 智能助手 LLM 开关：mock（默认，离线规则）| real（接 Anthropic Claude）。
AI_ASSISTANT_MODE="mock"

# 以下仅当 AI_ASSISTANT_MODE=real 时生效。
ANTHROPIC_API_KEY=""
AI_LLM_MODEL="claude-opus-4-8"
AI_LLM_MAX_TOKENS="1024"
AI_LLM_TIMEOUT_SECONDS="20"
