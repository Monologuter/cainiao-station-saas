# SEC-13：示例值均为占位，生产必改。用户名/口令勿沿用 cainiao/cainiao 等弱默认。
DATABASE_URL="postgresql://cainiao:CHANGE_ME_DB_PASSWORD@localhost:15432/cainiao?schema=public"
JWT_SECRET="CHANGE_ME_LONG_RANDOM_JWT_SECRET"
JWT_EXPIRES_IN="2h"
AI_SERVICE_TOKEN="CHANGE_ME_SHARED_AI_SERVICE_TOKEN"
REDIS_URL="redis://localhost:16379"
PORT=3100
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"

# AI 服务地址：backend 调用 ai-service（OCR / 智能助手 / 选格 / 预测）。
# 本机直跑用 127.0.0.1:8000；compose app profile 下走 http://ai-service:8000。
AI_SERVICE_URL="http://127.0.0.1:8000"

# 逾期件扫描定时任务（cron 表达式，BullMQ repeatable）。默认每日 02:00。
OVERDUE_SCAN_CRON="0 2 * * *"

# 对象存储（MinIO，S3 兼容）。本机端口错开：S3 API 19000 / 控制台 19001。
MINIO_ENDPOINT="localhost:19000"
MINIO_ROOT_USER="cainiao"
MINIO_ROOT_PASSWORD="CHANGE_ME_MINIO_PASSWORD"
MINIO_BUCKET="cainiao-files"
MINIO_USE_SSL="false"

# Real integrations are opt-in. Keep mock in local/CI unless sandbox credentials
# are available; missing required secrets will safely degrade to mock.
NOTIFY_SMS_PROVIDER=mock
NOTIFY_WECHAT_PROVIDER=mock
LOGISTICS_PROVIDER=mock
PAY_PROVIDER=mock

# Tencent Cloud SMS
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=

# WeChat Mini Program subscribe messages
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# KuaiDi100 logistics
KUAIDI100_KEY=
KUAIDI100_CUSTOMER=

# WeChat Pay
WXPAY_MCH_ID=
WXPAY_APP_ID=
WXPAY_API_V3_KEY=
WXPAY_PRIVATE_KEY=
WXPAY_CERT_SERIAL_NO=
WXPAY_PLATFORM_PUBLIC_KEY=
WXPAY_PLATFORM_CERT_SERIAL_NO=
WXPAY_NOTIFY_URL=
