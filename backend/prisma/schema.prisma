generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  PLATFORM
  STAFF
}

enum RoleScope {
  PLATFORM
  TENANT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ShelfStatus {
  ACTIVE
  DISABLED
}

enum SlotStatus {
  FREE
  OCCUPIED
  DISABLED
}

enum ParcelStatus {
  PENDING
  STORED
  PICKED_UP
  EXCEPTION
  RETURNED
}

enum ParcelEventType {
  INBOUND
  STORED
  PICKED_UP
  EXCEPTION
  RETURNED
}

model Tenant {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  ownerName    String
  contactPhone String
  status       TenantStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  users        User[]
  stations     Station[]
  shelves      Shelf[]
  slots        Slot[]
  parcels      Parcel[]
  parcelEvents ParcelEvent[]
}

model Station {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  code      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  shelves   Shelf[]
  slots     Slot[]
  parcels   Parcel[]

  @@index([tenantId])
}

model Shelf {
  id        String      @id @default(uuid()) @db.Uuid
  tenantId  String      @map("tenant_id") @db.Uuid
  stationId String      @map("station_id") @db.Uuid
  code      String
  name      String
  zone      String?
  status    ShelfStatus @default(ACTIVE)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")
  createdBy String?     @map("created_by") @db.Uuid
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  station   Station     @relation(fields: [stationId], references: [id])
  slots     Slot[]

  @@unique([stationId, code])
  @@index([tenantId, stationId])
  @@map("shelves")
}

model Slot {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @map("tenant_id") @db.Uuid
  stationId       String     @map("station_id") @db.Uuid
  shelfId         String     @map("shelf_id") @db.Uuid
  code            String
  rowNo           Int?       @map("row_no")
  levelNo         Int?       @map("level_no")
  colNo           Int?       @map("col_no")
  status          SlotStatus @default(FREE)
  currentParcelId String?    @map("current_parcel_id") @db.Uuid
  version         Int        @default(0)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")
  createdBy       String?    @map("created_by") @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  station         Station    @relation(fields: [stationId], references: [id])
  shelf           Shelf      @relation(fields: [shelfId], references: [id])
  parcels         Parcel[]

  @@unique([stationId, code])
  @@index([tenantId, stationId, status])
  @@map("slots")
}

model Parcel {
  id                String        @id @default(uuid()) @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  stationId         String        @map("station_id") @db.Uuid
  waybillNo         String        @map("waybill_no")
  carrier           String?
  receiverPhone     String        @map("receiver_phone")
  receiverPhoneTail String        @map("receiver_phone_tail")
  pickupCode        String?       @map("pickup_code")
  slotId            String?       @map("slot_id") @db.Uuid
  status            ParcelStatus  @default(PENDING)
  storedAt          DateTime?     @map("stored_at")
  pickedUpAt        DateTime?     @map("picked_up_at")
  version           Int           @default(0)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  deletedAt         DateTime?     @map("deleted_at")
  createdBy         String?       @map("created_by") @db.Uuid
  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  station           Station       @relation(fields: [stationId], references: [id])
  slot              Slot?         @relation(fields: [slotId], references: [id])
  events            ParcelEvent[]

  @@index([tenantId, stationId, status])
  @@index([tenantId, receiverPhone])
  @@index([tenantId, stationId, receiverPhoneTail, status])
  @@map("parcels")
}

model ParcelEvent {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @map("tenant_id") @db.Uuid
  parcelId   String           @map("parcel_id") @db.Uuid
  fromStatus ParcelStatus?    @map("from_status")
  toStatus   ParcelStatus     @map("to_status")
  eventType  ParcelEventType  @map("event_type")
  operatorId String?          @map("operator_id") @db.Uuid
  payload    Json?
  createdAt  DateTime         @default(now()) @map("created_at")
  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  parcel     Parcel           @relation(fields: [parcelId], references: [id])

  @@index([tenantId, parcelId, createdAt])
  @@map("parcel_events")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String?    @map("tenant_id") @db.Uuid
  type         UserType
  username     String
  passwordHash String
  phone        String?
  status       String     @default("active")
  createdAt    DateTime   @default(now())
  tenant       Tenant?    @relation(fields: [tenantId], references: [id])
  roles        UserRole[]

  @@unique([tenantId, username])
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String?          @map("tenant_id") @db.Uuid
  code        String
  name        String
  scope       RoleScope
  isBuiltin   Boolean          @default(false)
  users       UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, code])
}

model Permission {
  id     String           @id @default(uuid()) @db.Uuid
  code   String           @unique
  name   String
  module String
  roles  RolePermission[]
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}
