generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  PLATFORM
  STAFF
}

enum RoleScope {
  PLATFORM
  TENANT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ShelfStatus {
  ACTIVE
  DISABLED
}

enum SlotStatus {
  FREE
  OCCUPIED
  DISABLED
}

enum ParcelStatus {
  PENDING
  STORED
  PICKED_UP
  EXCEPTION
  RETURNED
}

enum ParcelEventType {
  INBOUND
  STORED
  PICKED_UP
  EXCEPTION
  RETURNED
}

enum NotifyChannelType {
  IN_APP
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum PickupAuthorizationStatus {
  ACTIVE
  REVOKED
}

enum ShipOrderChannel {
  STATION
  ONLINE
}

enum ShipOrderStatus {
  CREATED
  PAID
  COLLECTED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentBizType {
  SHIP_ORDER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum LogisticsNodeStatus {
  COLLECTED
  IN_TRANSIT
  ARRIVED
  OUT_FOR_DELIVERY
  DELIVERED
}

enum LogisticsTrackSource {
  MOCK
  PROVIDER
}

enum ExceptionType {
  DAMAGED
  MISDELIVERED
  UNCLAIMED
  REJECTED
  OVERSIZED
}

enum ExceptionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ExceptionResolution {
  CONTACT_COURIER
  RETURN
  RESTOCK
  VOID
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum PointRecordType {
  PICKUP
  SHIP
  CHECKIN
  COUPON_REDEEM
  EXPIRE
  ADJUST
  REFUND
}

enum CouponType {
  DISCOUNT
  RATE
  EXEMPT
}

enum CouponScene {
  PICKUP
  SHIP
  ALL
}

enum CouponTemplateStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CouponStatus {
  UNUSED
  USED
  EXPIRED
  FROZEN
}

enum CouponObtainedVia {
  POINT_REDEEM
  ISSUE
  CHECKIN_REWARD
}

model Consumer {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String   @unique @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  member    Member?

  @@map("consumers")
}

model Member {
  id                    String        @id @default(uuid()) @db.Uuid
  consumerId            String        @unique @map("consumer_id") @db.Uuid
  phone                 String        @unique @db.VarChar(20)
  level                 Int           @default(0) @db.SmallInt
  totalPoints           Int           @default(0) @map("total_points")
  availablePoints       Int           @default(0) @map("available_points")
  frozenPoints          Int           @default(0) @map("frozen_points")
  continuousCheckinDays Int           @default(0) @map("continuous_checkin_days")
  lastCheckinDate       DateTime?     @map("last_checkin_date") @db.Date
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  deletedAt             DateTime?     @map("deleted_at")
  consumer              Consumer      @relation(fields: [consumerId], references: [id])
  pointRecords          PointRecord[]
  coupons               Coupon[]

  @@index([level])
  @@map("members")
}

model PointRecord {
  id             String          @id @default(uuid()) @db.Uuid
  memberId       String          @map("member_id") @db.Uuid
  change         Int
  balanceAfter   Int             @map("balance_after")
  type           PointRecordType
  sourceTenantId String?         @map("source_tenant_id") @db.Uuid
  refType        String?         @map("ref_type") @db.VarChar(32)
  refId          String?         @map("ref_id") @db.VarChar(64)
  idempotencyKey String          @unique @map("idempotency_key") @db.VarChar(128)
  remark         String?         @db.VarChar(200)
  createdAt      DateTime        @default(now()) @map("created_at")
  member         Member          @relation(fields: [memberId], references: [id])

  @@index([memberId, createdAt])
  @@index([sourceTenantId])
  @@map("point_records")
}

model CouponTemplate {
  id          String               @id @default(uuid()) @db.Uuid
  tenantId    String               @map("tenant_id") @db.Uuid
  name        String               @db.VarChar(64)
  type        CouponType
  faceValue   Decimal              @map("face_value") @db.Decimal(10, 2)
  threshold   Decimal              @default(0) @db.Decimal(10, 2)
  scene       CouponScene
  costPoints  Int?                 @map("cost_points")
  totalStock  Int?                 @map("total_stock")
  issuedCount Int                  @default(0) @map("issued_count")
  validDays   Int                  @map("valid_days")
  status      CouponTemplateStatus @default(ACTIVE)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")
  createdBy   String?              @map("created_by") @db.Uuid
  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  coupons     Coupon[]

  @@index([tenantId, status])
  @@index([tenantId, scene])
  @@map("coupon_templates")
}

model Coupon {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @map("tenant_id") @db.Uuid
  templateId    String            @map("template_id") @db.Uuid
  memberId      String            @map("member_id") @db.Uuid
  code          String            @unique @db.VarChar(32)
  status        CouponStatus      @default(UNUSED)
  obtainedVia   CouponObtainedVia @map("obtained_via")
  pointRecordId String?           @map("point_record_id") @db.Uuid
  usedAt        DateTime?         @map("used_at")
  usedRefType   String?           @map("used_ref_type") @db.VarChar(32)
  usedRefId     String?           @map("used_ref_id") @db.VarChar(64)
  expireAt      DateTime          @map("expire_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  template      CouponTemplate    @relation(fields: [templateId], references: [id])
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  member        Member            @relation(fields: [memberId], references: [id])

  @@index([tenantId, memberId, status])
  @@index([expireAt, status])
  @@map("coupons")
}

model Tenant {
  id                   String                @id @default(uuid()) @db.Uuid
  name                 String
  ownerName            String
  contactPhone         String
  status               TenantStatus          @default(ACTIVE)
  createdAt            DateTime              @default(now())
  users                User[]
  stations             Station[]
  shelves              Shelf[]
  slots                Slot[]
  parcels              Parcel[]
  parcelEvents         ParcelEvent[]
  notifications        Notification[]
  notifyTemplates      NotifyTemplate[]
  pickupAuthorizations PickupAuthorization[]
  shipOrders           ShipOrder[]
  priceRules           PriceRule[]
  payments             Payment[]
  logisticsTracks      LogisticsTrack[]
  exceptionTickets     ExceptionTicket[]
  couponTemplates      CouponTemplate[]
  coupons              Coupon[]
}

model Station {
  id         String      @id @default(uuid()) @db.Uuid
  tenantId   String      @map("tenant_id") @db.Uuid
  name       String
  code       String
  createdAt  DateTime    @default(now())
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  shelves    Shelf[]
  slots      Slot[]
  parcels    Parcel[]
  shipOrders ShipOrder[]
  exceptions ExceptionTicket[]

  @@index([tenantId])
}

model Shelf {
  id        String      @id @default(uuid()) @db.Uuid
  tenantId  String      @map("tenant_id") @db.Uuid
  stationId String      @map("station_id") @db.Uuid
  code      String
  name      String
  zone      String?
  status    ShelfStatus @default(ACTIVE)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")
  createdBy String?     @map("created_by") @db.Uuid
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  station   Station     @relation(fields: [stationId], references: [id])
  slots     Slot[]

  @@unique([stationId, code])
  @@index([tenantId, stationId])
  @@map("shelves")
}

model Slot {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @map("tenant_id") @db.Uuid
  stationId       String     @map("station_id") @db.Uuid
  shelfId         String     @map("shelf_id") @db.Uuid
  code            String
  rowNo           Int?       @map("row_no")
  levelNo         Int?       @map("level_no")
  colNo           Int?       @map("col_no")
  status          SlotStatus @default(FREE)
  currentParcelId String?    @map("current_parcel_id") @db.Uuid
  version         Int        @default(0)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")
  createdBy       String?    @map("created_by") @db.Uuid
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  station         Station    @relation(fields: [stationId], references: [id])
  shelf           Shelf      @relation(fields: [shelfId], references: [id])
  parcels         Parcel[]

  @@unique([stationId, code])
  @@index([tenantId, stationId, status])
  @@map("slots")
}

model Parcel {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @map("tenant_id") @db.Uuid
  stationId         String         @map("station_id") @db.Uuid
  waybillNo         String         @map("waybill_no")
  carrier           String?
  receiverPhone     String         @map("receiver_phone")
  receiverPhoneTail String         @map("receiver_phone_tail")
  pickupCode        String?        @map("pickup_code")
  slotId            String?        @map("slot_id") @db.Uuid
  status            ParcelStatus   @default(PENDING)
  storedAt          DateTime?      @map("stored_at")
  pickedUpAt        DateTime?      @map("picked_up_at")
  lastOverdueLevel   Int            @default(0) @map("last_overdue_level")
  overdueReturnedAt  DateTime?      @map("overdue_returned_at")
  version           Int            @default(0)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")
  createdBy         String?        @map("created_by") @db.Uuid
  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  station           Station        @relation(fields: [stationId], references: [id])
  slot              Slot?          @relation(fields: [slotId], references: [id])
  events            ParcelEvent[]
  notifications     Notification[]
  exceptionTickets  ExceptionTicket[]

  @@index([tenantId, stationId, status])
  @@index([tenantId, receiverPhone])
  @@index([tenantId, stationId, receiverPhoneTail, status])
  @@map("parcels")
}

model ExceptionTicket {
  id                 String               @id @default(uuid()) @db.Uuid
  tenantId           String               @map("tenant_id") @db.Uuid
  stationId          String               @map("station_id") @db.Uuid
  parcelId           String?              @map("parcel_id") @db.Uuid
  code               String               @db.VarChar(40)
  type               ExceptionType
  status             ExceptionStatus      @default(OPEN)
  resolution         ExceptionResolution?
  severity           Severity?
  description        String
  evidenceUrls       Json                 @default("[]") @map("evidence_urls")
  assigneeId         String?              @map("assignee_id") @db.Uuid
  parcelStatusBefore ParcelStatus?        @map("parcel_status_before")
  openedAt           DateTime             @default(now()) @map("opened_at")
  resolvedAt         DateTime?            @map("resolved_at")
  resolutionNote     String?              @map("resolution_note")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  deletedAt          DateTime?            @map("deleted_at")
  createdBy          String?              @map("created_by") @db.Uuid
  tenant             Tenant               @relation(fields: [tenantId], references: [id])
  station            Station              @relation(fields: [stationId], references: [id])
  parcel             Parcel?              @relation(fields: [parcelId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, stationId, status])
  @@index([tenantId, parcelId])
  @@map("exceptions")
}

model ParcelEvent {
  id         String          @id @default(uuid()) @db.Uuid
  tenantId   String          @map("tenant_id") @db.Uuid
  parcelId   String          @map("parcel_id") @db.Uuid
  fromStatus ParcelStatus?   @map("from_status")
  toStatus   ParcelStatus    @map("to_status")
  eventType  ParcelEventType @map("event_type")
  operatorId String?         @map("operator_id") @db.Uuid
  payload    Json?
  createdAt  DateTime        @default(now()) @map("created_at")
  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  parcel     Parcel          @relation(fields: [parcelId], references: [id])

  @@index([tenantId, parcelId, createdAt])
  @@map("parcel_events")
}

model Notification {
  id            String             @id @default(uuid()) @db.Uuid
  tenantId      String             @map("tenant_id") @db.Uuid
  parcelId      String?            @map("parcel_id") @db.Uuid
  receiverPhone String             @map("receiver_phone")
  channel       NotifyChannelType
  templateCode  String             @map("template_code")
  content       String
  status        NotificationStatus @default(PENDING)
  dedupKey      String             @map("dedup_key")
  sentAt        DateTime?          @map("sent_at")
  error         String?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  deletedAt     DateTime?          @map("deleted_at")
  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  parcel        Parcel?            @relation(fields: [parcelId], references: [id])

  @@unique([tenantId, dedupKey])
  @@index([tenantId, parcelId])
  @@index([tenantId, receiverPhone])
  @@map("notifications")
}

model NotifyTemplate {
  id        String            @id @default(uuid()) @db.Uuid
  tenantId  String?           @map("tenant_id") @db.Uuid
  code      String
  channel   NotifyChannelType
  content   String
  enabled   Boolean           @default(true)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  deletedAt DateTime?         @map("deleted_at")
  tenant    Tenant?           @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code, channel])
  @@map("notify_templates")
}

model PickupAuthorization {
  id              String                    @id @default(uuid()) @db.Uuid
  tenantId        String                    @map("tenant_id") @db.Uuid
  ownerPhone      String                    @map("owner_phone")
  authorizedPhone String                    @map("authorized_phone")
  status          PickupAuthorizationStatus @default(ACTIVE)
  expiresAt       DateTime?                 @map("expires_at")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")
  deletedAt       DateTime?                 @map("deleted_at")
  createdBy       String?                   @map("created_by") @db.Uuid
  tenant          Tenant                    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, ownerPhone, status])
  @@index([tenantId, authorizedPhone, status])
  @@map("pickup_authorizations")
}

model ShipOrder {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @map("tenant_id") @db.Uuid
  stationId         String?          @map("station_id") @db.Uuid
  orderNo           String           @map("order_no")
  channel           ShipOrderChannel
  status            ShipOrderStatus  @default(CREATED)
  senderJson        Json             @map("sender_json")
  receiverJson      Json             @map("receiver_json")
  itemJson          Json             @map("item_json")
  weightGram        Int              @map("weight_gram")
  courierCode       String           @map("courier_code") @db.VarChar(16)
  courierName       String           @map("courier_name") @db.VarChar(32)
  quoteAmount       Int              @map("quote_amount")
  quoteSnapshotJson Json             @map("quote_snapshot_json")
  consumerId        String?          @map("consumer_id")
  waybillNo         String?          @map("waybill_no") @db.VarChar(40)
  paidAt            DateTime?        @map("paid_at")
  collectedAt       DateTime?        @map("collected_at")
  deliveredAt       DateTime?        @map("delivered_at")
  cancelledAt       DateTime?        @map("cancelled_at")
  version           Int              @default(0)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")
  createdBy         String?          @map("created_by") @db.Uuid
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  station           Station?         @relation(fields: [stationId], references: [id])
  logisticsTracks   LogisticsTrack[]

  @@unique([tenantId, orderNo])
  @@index([tenantId, status])
  @@index([tenantId, stationId])
  @@index([tenantId, consumerId])
  @@index([waybillNo])
  @@map("ship_orders")
}

model PriceRule {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  courierCode     String    @map("courier_code") @db.VarChar(16)
  courierName     String    @map("courier_name") @db.VarChar(32)
  zone            String    @db.VarChar(16)
  firstWeightGram Int       @default(1000) @map("first_weight_gram")
  firstPrice      Int       @map("first_price")
  addUnitGram     Int       @default(1000) @map("add_unit_gram")
  addPrice        Int       @map("add_price")
  zoneFactor      Decimal   @default(1.00) @map("zone_factor") @db.Decimal(4, 2)
  estHours        Int       @map("est_hours")
  enabled         Boolean   @default(true)
  priority        Int       @default(0)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  createdBy       String?   @map("created_by") @db.Uuid
  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, courierCode, zone, enabled])
  @@map("price_rules")
}

model Payment {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  bizType        PaymentBizType @map("biz_type")
  bizId          String         @map("biz_id") @db.Uuid
  channel        String         @db.VarChar(16)
  amount         Int
  status         PaymentStatus  @default(PENDING)
  idempotencyKey String         @map("idempotency_key") @db.VarChar(64)
  outTradeNo     String         @map("out_trade_no") @db.VarChar(64)
  paidAt         DateTime?      @map("paid_at")
  rawJson        Json           @map("raw_json")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")
  createdBy      String?        @map("created_by") @db.Uuid
  tenant         Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, bizType, bizId])
  @@map("payments")
}

model LogisticsTrack {
  id          String               @id @default(uuid()) @db.Uuid
  tenantId    String               @map("tenant_id") @db.Uuid
  shipOrderId String               @map("ship_order_id") @db.Uuid
  waybillNo   String               @map("waybill_no") @db.VarChar(40)
  seq         Int
  nodeStatus  LogisticsNodeStatus  @map("node_status")
  location    String               @db.VarChar(64)
  description String               @db.VarChar(255)
  happenedAt  DateTime             @map("happened_at")
  source      LogisticsTrackSource
  createdAt   DateTime             @default(now()) @map("created_at")
  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  shipOrder   ShipOrder            @relation(fields: [shipOrderId], references: [id])

  @@unique([shipOrderId, seq])
  @@index([tenantId, shipOrderId])
  @@index([waybillNo])
  @@map("logistics_tracks")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String?    @map("tenant_id") @db.Uuid
  type         UserType
  username     String
  passwordHash String
  phone        String?
  status       String     @default("active")
  createdAt    DateTime   @default(now())
  tenant       Tenant?    @relation(fields: [tenantId], references: [id])
  roles        UserRole[]

  @@unique([tenantId, username])
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String?          @map("tenant_id") @db.Uuid
  code        String
  name        String
  scope       RoleScope
  isBuiltin   Boolean          @default(false)
  users       UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, code])
}

model Permission {
  id     String           @id @default(uuid()) @db.Uuid
  code   String           @unique
  name   String
  module String
  roles  RolePermission[]
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}
