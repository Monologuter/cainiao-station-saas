generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  PLATFORM
  STAFF
}

enum RoleScope {
  PLATFORM
  TENANT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ShelfStatus {
  ACTIVE
  DISABLED
}

enum SlotStatus {
  FREE
  OCCUPIED
  DISABLED
}

enum ParcelStatus {
  PENDING
  STORED
  PICKED_UP
  EXCEPTION
  RETURNED
}

enum ParcelSize {
  S
  M
  L
}

enum ParcelEventType {
  INBOUND
  STORED
  PICKED_UP
  EXCEPTION
  RETURNED
}

enum NotifyChannelType {
  IN_APP
  SMS
  WECHAT
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum PickupAuthorizationStatus {
  ACTIVE
  REVOKED
}

enum ShipOrderChannel {
  STATION
  ONLINE
}

enum ShipOrderStatus {
  CREATED
  PAID
  COLLECTED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentBizType {
  SHIP_ORDER
  SUBSCRIPTION_INVOICE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum LogisticsNodeStatus {
  COLLECTED
  IN_TRANSIT
  ARRIVED
  OUT_FOR_DELIVERY
  DELIVERED
}

enum LogisticsTrackSource {
  MOCK
  PROVIDER
}

enum ExceptionType {
  DAMAGED
  MISDELIVERED
  UNCLAIMED
  REJECTED
  OVERSIZED
}

enum ExceptionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ExceptionResolution {
  CONTACT_COURIER
  RETURN
  RESTOCK
  VOID
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum PointRecordType {
  PICKUP
  SHIP
  CHECKIN
  COUPON_REDEEM
  EXPIRE
  ADJUST
  REFUND
}

enum CouponType {
  DISCOUNT
  RATE
  EXEMPT
}

enum CouponScene {
  PICKUP
  SHIP
  ALL
}

enum CouponTemplateStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CouponStatus {
  UNUSED
  USED
  EXPIRED
  FROZEN
}

enum CouponObtainedVia {
  POINT_REDEEM
  ISSUE
  CHECKIN_REWARD
}

enum ReviewTargetType {
  PICKUP
  SHIP
}

enum ReviewStatus {
  PUBLISHED
  REPLIED
  HIDDEN
}

enum ComplaintType {
  DAMAGE
  LOST
  SERVICE
  WRONG
  OTHER
}

enum ComplaintStatus {
  PENDING
  PROCESSING
  RESOLVED
  CLOSED
}

enum ReportJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum ReportFormat {
  CSV
  XLSX
}

enum ReportType {
  DAILY_SUMMARY
  INBOUND_DETAIL
  PICKUP_DETAIL
  STATION_COMPARE
}

enum ForecastGranularity {
  DAY
  HOUR
}

enum ForecastMethod {
  MA
  HOLT_WINTERS
  FALLBACK_MEAN
}

enum PlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
  EXPIRED
}

enum UsageMetric {
  SMS
  PARCELS
  EXTRA_STATIONS
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  OVERDUE
  VOID
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EntityType {
  INDIVIDUAL
  COMPANY
}

enum AuditActorType {
  PLATFORM
  STAFF
  SYSTEM
}

enum AuditResult {
  SUCCESS
  FAILURE
}

enum ConfigValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum OcrRecognitionStatus {
  RECOGNIZED
  LOW_CONFIDENCE
  FAILED
  CONFIRMED
  FALLBACK_MANUAL
}

enum FaqCategory {
  PICKUP
  SHIPPING
  PARCEL_STATUS
  MEMBER
  GENERAL
}

enum AiActorType {
  CONSUMER
  STAFF
}

enum AiChannel {
  USER_APP
  STATION_WEB
}

enum AiAssistantMode {
  MOCK
  REAL
}

enum AiConversationStatus {
  ACTIVE
  CLOSED
}

enum AiMessageRole {
  USER
  ASSISTANT
  TOOL
}

model Consumer {
  id                            String                         @id @default(uuid()) @db.Uuid
  phone                         String                         @unique @db.VarChar(20)
  createdAt                     DateTime                       @default(now()) @map("created_at")
  updatedAt                     DateTime                       @updatedAt @map("updated_at")
  member                        Member?
  wechatSubscribeAuthorizations WechatSubscribeAuthorization[]

  @@map("consumers")
}

model Member {
  id                    String          @id @default(uuid()) @db.Uuid
  consumerId            String          @unique @map("consumer_id") @db.Uuid
  phone                 String          @unique @db.VarChar(20)
  level                 Int             @default(0) @db.SmallInt
  totalPoints           Int             @default(0) @map("total_points")
  availablePoints       Int             @default(0) @map("available_points")
  frozenPoints          Int             @default(0) @map("frozen_points")
  continuousCheckinDays Int             @default(0) @map("continuous_checkin_days")
  lastCheckinDate       DateTime?       @map("last_checkin_date") @db.Date
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  deletedAt             DateTime?       @map("deleted_at")
  consumer              Consumer        @relation(fields: [consumerId], references: [id])
  pointRecords          PointRecord[]
  coupons               Coupon[]
  checkins              MemberCheckin[]
  reviews               Review[]
  complaints            Complaint[]

  @@index([level])
  @@map("members")
}

model PointRecord {
  id             String          @id @default(uuid()) @db.Uuid
  memberId       String          @map("member_id") @db.Uuid
  change         Int
  balanceAfter   Int             @map("balance_after")
  type           PointRecordType
  sourceTenantId String?         @map("source_tenant_id") @db.Uuid
  refType        String?         @map("ref_type") @db.VarChar(32)
  refId          String?         @map("ref_id") @db.VarChar(64)
  idempotencyKey String          @unique @map("idempotency_key") @db.VarChar(128)
  remark         String?         @db.VarChar(200)
  createdAt      DateTime        @default(now()) @map("created_at")
  member         Member          @relation(fields: [memberId], references: [id])
  checkin        MemberCheckin?

  @@index([memberId, createdAt])
  @@index([sourceTenantId])
  @@map("point_records")
}

model MemberCheckin {
  id             String      @id @default(uuid()) @db.Uuid
  memberId       String      @map("member_id") @db.Uuid
  checkinDate    DateTime    @map("checkin_date") @db.Date
  rewardPoints   Int         @map("reward_points")
  continuousDays Int         @map("continuous_days")
  pointRecordId  String      @unique @map("point_record_id") @db.Uuid
  createdAt      DateTime    @default(now()) @map("created_at")
  member         Member      @relation(fields: [memberId], references: [id])
  pointRecord    PointRecord @relation(fields: [pointRecordId], references: [id])

  @@unique([memberId, checkinDate])
  @@map("member_checkins")
}

model CouponTemplate {
  id          String               @id @default(uuid()) @db.Uuid
  tenantId    String               @map("tenant_id") @db.Uuid
  name        String               @db.VarChar(64)
  type        CouponType
  faceValue   Decimal              @map("face_value") @db.Decimal(10, 2)
  threshold   Decimal              @default(0) @db.Decimal(10, 2)
  scene       CouponScene
  costPoints  Int?                 @map("cost_points")
  totalStock  Int?                 @map("total_stock")
  issuedCount Int                  @default(0) @map("issued_count")
  validDays   Int                  @map("valid_days")
  status      CouponTemplateStatus @default(ACTIVE)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")
  createdBy   String?              @map("created_by") @db.Uuid
  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  coupons     Coupon[]

  @@index([tenantId, status])
  @@index([tenantId, scene])
  @@map("coupon_templates")
}

model Coupon {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @map("tenant_id") @db.Uuid
  templateId    String            @map("template_id") @db.Uuid
  memberId      String            @map("member_id") @db.Uuid
  code          String            @unique @db.VarChar(32)
  status        CouponStatus      @default(UNUSED)
  obtainedVia   CouponObtainedVia @map("obtained_via")
  pointRecordId String?           @map("point_record_id") @db.Uuid
  usedAt        DateTime?         @map("used_at")
  usedRefType   String?           @map("used_ref_type") @db.VarChar(32)
  usedRefId     String?           @map("used_ref_id") @db.VarChar(64)
  expireAt      DateTime          @map("expire_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  template      CouponTemplate    @relation(fields: [templateId], references: [id])
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  member        Member            @relation(fields: [memberId], references: [id])

  @@index([tenantId, memberId, status])
  @@index([expireAt, status])
  @@map("coupons")
}

model Review {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @map("tenant_id") @db.Uuid
  stationId     String           @map("station_id") @db.Uuid
  memberId      String           @map("member_id") @db.Uuid
  consumerPhone String           @map("consumer_phone") @db.VarChar(20)
  targetType    ReviewTargetType @map("target_type")
  refType       String           @map("ref_type") @db.VarChar(32)
  refId         String           @map("ref_id") @db.VarChar(64)
  rating        Int              @db.SmallInt
  tags          String[]         @default([])
  content       String?          @db.VarChar(500)
  images        String[]         @default([])
  status        ReviewStatus     @default(PUBLISHED)
  replyContent  String?          @map("reply_content") @db.VarChar(500)
  repliedBy     String?          @map("replied_by") @db.Uuid
  repliedAt     DateTime?        @map("replied_at")
  hiddenBy      String?          @map("hidden_by") @db.Uuid
  hiddenAt      DateTime?        @map("hidden_at")
  hideReason    String?          @map("hide_reason") @db.VarChar(500)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  station       Station          @relation(fields: [stationId], references: [id])
  member        Member           @relation(fields: [memberId], references: [id])

  @@unique([tenantId, refType, refId, memberId])
  @@index([tenantId, stationId, createdAt])
  @@index([tenantId, rating])
  @@map("reviews")
}

model Complaint {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  stationId     String          @map("station_id") @db.Uuid
  memberId      String          @map("member_id") @db.Uuid
  consumerPhone String          @map("consumer_phone") @db.VarChar(20)
  type          ComplaintType
  refType       String?         @map("ref_type") @db.VarChar(32)
  refId         String?         @map("ref_id") @db.VarChar(64)
  content       String          @db.VarChar(1000)
  images        String[]        @default([])
  status        ComplaintStatus @default(PENDING)
  handleNote    String?         @map("handle_note") @db.VarChar(1000)
  handledBy     String?         @map("handled_by") @db.Uuid
  handledAt     DateTime?       @map("handled_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  station       Station         @relation(fields: [stationId], references: [id])
  member        Member          @relation(fields: [memberId], references: [id])

  @@index([tenantId, stationId, status])
  @@index([tenantId, memberId, status])
  @@index([tenantId, createdAt])
  @@map("complaints")
}

model MetricDaily {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  stationId String?  @map("station_id") @db.Uuid
  statDate  DateTime @map("stat_date") @db.Date
  metric    String   @db.VarChar(40)
  value     BigInt   @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  station   Station? @relation(fields: [stationId], references: [id])

  @@unique([tenantId, stationId, statDate, metric])
  @@index([tenantId, statDate, metric])
  @@index([tenantId, stationId, statDate])
  @@map("metric_daily")
}

model VolumeForecast {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  stationId       String              @map("station_id") @db.Uuid
  targetDate      DateTime            @map("target_date") @db.Date
  granularity     ForecastGranularity
  predictedVolume Int                 @map("predicted_volume")
  hourBreakdown   Json?               @map("hour_breakdown")
  method          ForecastMethod
  lowerBound      Int                 @map("lower_bound")
  upperBound      Int                 @map("upper_bound")
  actualVolume    Int?                @map("actual_volume")
  generatedAt     DateTime            @default(now()) @map("generated_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  station         Station             @relation(fields: [stationId], references: [id])

  @@index([tenantId, stationId, targetDate])
  @@index([tenantId, stationId, granularity, generatedAt])
  @@map("volume_forecasts")
}

model ReportJob {
  id        String          @id @default(uuid()) @db.Uuid
  tenantId  String          @map("tenant_id") @db.Uuid
  stationId String?         @map("station_id") @db.Uuid
  type      ReportType
  rangeFrom DateTime        @map("range_from") @db.Date
  rangeTo   DateTime        @map("range_to") @db.Date
  format    ReportFormat
  status    ReportJobStatus @default(PENDING)
  fileKey   String?         @map("file_key") @db.VarChar(255)
  error     String?         @db.Text
  createdBy String          @map("created_by") @db.Uuid
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  station   Station?        @relation(fields: [stationId], references: [id])

  @@index([tenantId, status, createdAt])
  @@index([tenantId, stationId, createdAt])
  @@map("report_jobs")
}

model BillingPlan {
  id            String         @id @default(uuid()) @db.Uuid
  code          String         @unique @db.VarChar(40)
  name          String         @db.VarChar(80)
  monthlyPrice  BigInt         @map("monthly_price")
  currency      String         @default("CNY") @db.Char(3)
  quotas        Json           @default("{}")
  overagePrices Json           @default("{}") @map("overage_prices")
  billingPeriod BillingPeriod  @default(MONTHLY) @map("billing_period")
  status        PlanStatus     @default(DRAFT)
  sort          Int            @default(0)
  description   String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  createdBy     String?        @map("created_by") @db.Uuid
  subscriptions Subscription[]

  @@index([status, sort])
  @@map("plans")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  tenantId           String             @map("tenant_id") @db.Uuid
  stationId          String?            @map("station_id") @db.Uuid
  planId             String             @map("plan_id") @db.Uuid
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  nextBillingAt      DateTime           @map("next_billing_at")
  autoRenew          Boolean            @default(true) @map("auto_renew")
  startedAt          DateTime           @map("started_at")
  canceledAt         DateTime?          @map("canceled_at")
  planSnapshot       Json               @map("plan_snapshot")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  deletedAt          DateTime?          @map("deleted_at")
  createdBy          String?            @map("created_by") @db.Uuid
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  station            Station?           @relation(fields: [stationId], references: [id])
  plan               BillingPlan        @relation(fields: [planId], references: [id])
  usageRecords       UsageRecord[]
  usageDedups        UsageDedup[]
  invoices           Invoice[]

  @@index([tenantId, status])
  @@index([tenantId, stationId])
  @@index([nextBillingAt])
  @@map("subscriptions")
}

model UsageRecord {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  subscriptionId String       @map("subscription_id") @db.Uuid
  periodStart    DateTime     @map("period_start")
  metric         UsageMetric
  quantity       BigInt       @default(0)
  lastEventAt    DateTime     @default(now()) @map("last_event_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, periodStart, metric])
  @@index([tenantId, subscriptionId, periodStart])
  @@index([tenantId, metric])
  @@map("usage_records")
}

model UsageDedup {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  eventId        String        @map("event_id") @db.VarChar(120)
  subscriptionId String?       @map("subscription_id") @db.Uuid
  metric         UsageMetric?
  createdAt      DateTime      @default(now()) @map("created_at")
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  @@unique([tenantId, eventId])
  @@index([tenantId, createdAt])
  @@map("usage_dedup")
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  subscriptionId String        @map("subscription_id") @db.Uuid
  code           String        @db.VarChar(40)
  periodStart    DateTime      @map("period_start")
  periodEnd      DateTime      @map("period_end")
  status         InvoiceStatus @default(DRAFT)
  baseAmount     BigInt        @default(0) @map("base_amount")
  overageAmount  BigInt        @default(0) @map("overage_amount")
  totalAmount    BigInt        @default(0) @map("total_amount")
  currency       String        @default("CNY") @db.Char(3)
  lineItems      Json          @default("[]") @map("line_items")
  issuedAt       DateTime      @map("issued_at")
  dueAt          DateTime      @map("due_at")
  paidAt         DateTime?     @map("paid_at")
  paymentId      String?       @map("payment_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")
  createdBy      String?       @map("created_by") @db.Uuid
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  payment        Payment?      @relation(fields: [paymentId], references: [id])

  @@unique([tenantId, code])
  @@unique([subscriptionId, periodStart])
  @@index([tenantId, status])
  @@index([status, dueAt])
  @@index([tenantId, subscriptionId])
  @@map("invoices")
}

model TenantApplication {
  id                String            @id @default(uuid()) @db.Uuid
  applicationNo     String            @unique @map("application_no") @db.VarChar(40)
  status            ApplicationStatus @default(PENDING)
  entityType        EntityType        @map("entity_type")
  entityName        String            @map("entity_name") @db.VarChar(120)
  unifiedCreditCode String?           @map("unified_credit_code") @db.VarChar(64)
  regionCode        String            @map("region_code") @db.VarChar(20)
  contactName       String            @map("contact_name") @db.VarChar(60)
  contactPhone      String            @map("contact_phone") @db.VarChar(20)
  contactEmail      String?           @map("contact_email") @db.VarChar(120)
  stationName       String            @map("station_name") @db.VarChar(120)
  stationAddress    String            @map("station_address") @db.VarChar(255)
  proposedPlanCode  String?           @map("proposed_plan_code") @db.VarChar(40)
  qualifications    Json              @default("[]")
  reviewedBy        String?           @map("reviewed_by") @db.Uuid
  reviewedAt        DateTime?         @map("reviewed_at")
  rejectReason      String?           @map("reject_reason") @db.VarChar(500)
  approvedTenantId  String?           @map("approved_tenant_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")

  @@index([status, createdAt])
  @@index([contactPhone])
  @@map("tenant_applications")
}

model AuditLog {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String?        @map("tenant_id") @db.Uuid
  actorId      String?        @map("actor_id") @db.Uuid
  actorType    AuditActorType @map("actor_type")
  actorName    String?        @map("actor_name") @db.VarChar(80)
  action       String         @db.VarChar(80)
  resourceType String         @map("resource_type") @db.VarChar(80)
  resourceId   String?        @map("resource_id") @db.VarChar(80)
  result       AuditResult
  summary      String?        @db.VarChar(500)
  before       Json?
  after        Json?
  diff         Json?
  ip           String?        @db.VarChar(64)
  userAgent    String?        @map("user_agent") @db.VarChar(300)
  requestId    String?        @map("request_id") @db.VarChar(80)
  errorCode    String?        @map("error_code") @db.VarChar(60)
  errorMessage String?        @map("error_message") @db.VarChar(300)
  createdAt    DateTime       @default(now()) @map("created_at")
  tenant       Tenant?        @relation(fields: [tenantId], references: [id])
  actor        User?          @relation(fields: [actorId], references: [id])

  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([resourceType, resourceId])
  @@index([result, createdAt])
  @@map("audit_logs")
}

model Dictionary {
  id          String     @id @default(uuid()) @db.Uuid
  type        String     @unique @db.VarChar(60)
  name        String     @db.VarChar(80)
  description String?    @db.VarChar(255)
  enabled     Boolean    @default(true)
  sort        Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  items       DictItem[]

  @@index([enabled, sort])
  @@map("dictionaries")
}

model DictItem {
  id           String     @id @default(uuid()) @db.Uuid
  dictionaryId String     @map("dictionary_id") @db.Uuid
  code         String     @db.VarChar(80)
  label        String     @db.VarChar(120)
  value        Json?
